# ╔══════════════════════════════════════════════════════════════╗
# ║   QUIZBOT — Environment variables                            ║
# ║   Copy to `.env` and fill in your real values.               ║
# ║   Never commit your real .env to git.                        ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Pyrogram (main.py) ───────────────────────────────────────
# Get API_ID & API_HASH from https://my.telegram.org
API_ID=
API_HASH=
BOT_TOKEN=

# ── Optional second bot token used by helper API calls ───────
BOT_TOKEN_2=

# ── MongoDB ──────────────────────────────────────────────────
# Primary DB (users, quizzes metadata, sessions)
MONGO_URI=
# Secondary DB (replica / overflow)
MONGO_URI_2=
# Async DB used by the question_set / quizzes collection
MONGO_URIX=
DB_NAME=quiz_bot

# ── Owner & Groups ───────────────────────────────────────────
# Space-separated list of Telegram user IDs that own the bot
OWNER_ID=
# Optional channel / group IDs (set to 0 or leave blank to disable)
LOG_GROUP=0
FORCE_SUB=0
BOT_GROUP=0
CHANNEL_ID=0

# ── Encryption (only needed for encrypted quiz import/export) ─
MASTER_KEY=
IV_KEY=

# ── Limits ───────────────────────────────────────────────────
FREEMIUM_LIMIT=0
PREMIUM_LIMIT=500

# ── Optional MySQL panel sync ────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASS=
MYSQL_DB=quizbot

# ── Optional integrations ────────────────────────────────────
PAY_API=
YT_COOKIES=
INSTA_COOKIES=
UMODE=
FREE_BOT=true
